## -------- LLM Provider API Keys (set the ones you want) -------- ##
# For ChatCompletionsClient (a few examples, compatible with any chat completions API)
OPENROUTER_API_KEY=       # https://openrouter.ai/keys - default for ChatCompletionsClient
OPENAI_API_KEY=           # https://platform.openai.com/api-keys
DEEPSEEK_API_KEY=         # https://platform.deepseek.com/api_keys

# For LiteLLM (a few examples, see full model list at https://models.litellm.ai/)
ANTHROPIC_API_KEY=        # https://console.anthropic.com/settings/keys
GOOGLE_API_KEY=           # https://aistudio.google.com/app/apikey

## -------------------------- Web tools -------------------------- ##
BRAVE_API_KEY=            # https://brave.com/search/api/ - required for web_search

## ------------------------ Code execution ----------------------- ##
E2B_API_KEY=              # https://e2b.dev/docs - required for E2BCodeExecToolProvider

## --------------------- AgentIF-OneDay runs --------------------- ##
# OpenAI-compatible chat-completions model settings used by:
#   python -m evals.agentif_oneday ...
STIRRUP_MODEL=
STIRRUP_API_KEY=
STIRRUP_BASE_URL=

# Local AgentIF-OneDay dataset path. Defaults to this path when unset.
AGENTIF_ONEDAY_DATA_ROOT=/home/shangguanyike/AgentIF-OneDay/agentif_oneday_data

# Browser-use settings. Headless=false is usually more stable for anti-bot pages.
STIRRUP_BROWSER_HEADLESS=false
STIRRUP_BROWSER_EXECUTABLE_PATH=/usr/bin/google-chrome
STIRRUP_BROWSER_CDP_URL=
STIRRUP_BROWSER_PROFILE_DIR=/home/shangguanyike/stirrup_update/stirrup_agent/.browser_profile
STIRRUP_BROWSER_TIMEZONE=America/Los_Angeles
STIRRUP_CF_RETRY_ATTEMPTS=2
STIRRUP_CF_RETRY_WAIT_SECONDS=8
